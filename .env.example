# Crawl4AI Configuration
#Locally ran in docker or external service - easily setup with docker compose - see crawl4ai github https://github.com/unclecode/crawl4ai
# Base URL: CRAWL4AI_URL or CRAWL4AI_BASE_URL (either name is accepted)
# CRAWL4AI_URL=https://your-crawl4ai-host
# Local Docker Use
# CRAWL4AI_BASE_URL=http://crawl4ai:11235 
CRAWL4AI_BASE_URL=your_crawl4ai_base_url

# API key is sent as header x-api-key: <value> (not Authorization: Bearer). CRAWL4AI_API_KEY or CRAWL4AI_API_TOKEN.
CRAWL4AI_API_KEY=your_crawl4ai_api_key
# CRAWL4AI_API_TOKEN=

# Traefik / Coolify Basic auth on the public URL (optional): Authorization: Basic user:pass
# CRAWL4AI_USER=
# CRAWL4AI_PASSWORD=
# (alias) CRAWL4AI_PASS=
# Optional override if your proxy expects a different header name for the Crawl4AI key
# CRAWL4AI_API_KEY_HEADER=x-api-key

# Supabase Configuration
# Option 1: Use a PostgreSQL connection string for Supabase connection pooler  this is free tier with ipv4 access
# SUPABASE_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-us-east-2.pooler.supabase.com:5432/postgres

# Option 2: Use a single URL (can be with or without protocol) supabase github https://github.com/supabase/supabase , example http://192.168.1.20:54322
SUPABASE_URL=your_supabase_host:port

# Option 3: Or use individual components
# SUPABASE_HOST=your_supabase_host
# SUPABASE_PORT=your_supabase_port

# Database credentials 
SUPABASE_DB=postgres
# For remote Supabase with connection pooler, you can also specify a different database user
# DB_USER=postgres.[YOUR-PROJECT-REF]
SUPABASE_KEY=postgres
SUPABASE_PASSWORD=postgres

# OpenAI Configuration
OPENAI_API_KEY=sk-proj-
# Model to use for embeddings
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Model to use for title and summary generation and chat analysis
OPENAI_CONTENT_MODEL=gpt-4o-mini

# API Hardening
# Optional comma-separated keys. If set, every /api request must send x-api-key or Authorization: Bearer.
# SCC_API_KEYS=
# Frontend value when SCC_API_KEYS is enabled:
# VITE_API_KEY=
# Comma-separated browser origins for CORS. Leave blank for local permissive mode.
# API_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
#
# ----- Supa Crawl API authentication (port 8001) -----
# Optional Bearer token: when disabled (default), all requests allowed (typical on a private LAN).
# When enabled: non-localhost clients must send Authorization: Bearer <SUPA_API_KEY> (or legacy SCC_API_KEYS / API_KEYS, or a WebUI JWT after login).
# Localhost (127.0.0.1 / ::1) is always trusted without a key. Behind a reverse proxy, set trust forwarded IP + CIDRs as needed.
# SUPA_API_AUTH=false
# openssl rand -hex 32
# SUPA_API_KEY=
# Trust X-Forwarded-For for client IP (use with a trusted proxy only)
# SUPA_API_TRUST_FORWARDED=false
# Extra trusted CIDRs (comma-separated), e.g. Docker bridge: 172.16.0.0/12
# Docker Compose (docker/docker-compose.yml) defaults SUPA_API_TRUST_CIDRS for the api service so
# Vite-proxied requests from the frontend container are not 401 when auth is on. Override in .env if needed.
# SUPA_API_TRUST_CIDRS=
#
# Rate limit for GET /api/query only (requests per minute per IP). 0 = disabled. Default: 30
# QUERY_RATE_LIMIT_PER_MINUTE=30
#
# ----- WebUI authentication (custom login page) -----
# When set: browser must POST /api/auth/webui/login with this password; session uses a JWT (Authorization: Bearer).
# When empty/unset: no WebUI login (typical on private networks).
# WEBUI_PASSWORD=
# Optional JWT signing secret (if unset, derived from WEBUI_PASSWORD)
# WEBUI_SECRET=
# WEBUI_TOKEN_EXPIRY_DAYS=30
#
# Local HTTP API for other apps / tools (same process reads this .env — no extra client config for chat limits):
#   GET  /api/search?query=...   or   GET /api/query?query=...   (alias) — RAG retrieval only, no LLM
#   POST /api/chat               — full chat (uses CHAT_MAX_COMPLETION_TOKENS, CHAT_MODEL, BRAVE_* from .env)
#   GET  /api                    — JSON route map

# Application logging (rotating files under APP_LOG_DIR; also mirrored to stderr)
# LOG_LEVEL=INFO
# APP_LOG_DIR=log
# LOG_FILE=app.log
# One line per HTTP request: api_http METHOD /path -> status ms (in app.log). Disable to reduce noise:
# API_ACCESS_LOG=false
#
# Rotation — default is SIZE-based (no calendar retention):
# LOG_MAX_BYTES=10485760
# LOG_BACKUP_COUNT=5
#
# Time-based (Docker-friendly, no cron): daily rollover at midnight UTC; keep ~N days of app.log.* files.
# When set > 0, LOG_MAX_BYTES / LOG_BACKUP_COUNT are not used for the main file.
# LOG_RETENTION_DAYS=31
#
# Per-crawl detail files: ${APP_LOG_DIR}/crawl/<UTC-timestamp>-site<id>-job<id>.log
# Delete crawl *.log files older than N days once at startup (optional; no cron):
# CRAWL_LOG_MAX_AGE_DAYS=31
#
# Operator / audit log (deletes, etc.) — separate from noisy app.log traffic; same directory as APP_LOG_DIR
# AUDIT_LOG_ENABLED=true
# AUDIT_LOG_FILE=audit.log
# AUDIT_LOG_MAX_BYTES=5242880
# AUDIT_LOG_BACKUP_COUNT=5
# Brave Search — LLM Context (web grounding for chat). Paid Search plan: https://api.search.brave.com/res/v1/llm/context
# BRAVE_API_KEY=
# When to add web context: off | when_empty | when_weak | always | auto (default when_empty)
# when_empty: Brave when RAG has no hits, OR when the user explicitly asks for web/Brave search
# auto = explicit web-search phrasing OR empty RAG OR weak RAG (see BRAVE_WEAK_THRESHOLD)
# BRAVE_WEB_CONTEXT=when_empty
# If BRAVE_WEB_CONTEXT=when_weak, merge when max RAG similarity is below this (0–1)
# BRAVE_WEAK_THRESHOLD=0.35
# BRAVE_MAX_TOKENS=4096
# BRAVE_COUNT=12
# BRAVE_MAX_SNIPPETS=50
# BRAVE_CONTEXT_THRESHOLD_MODE=balanced
# BRAVE_COUNTRY=us
# BRAVE_SEARCH_LANG=en
# BRAVE_HTTP_TIMEOUT=30
# BRAVE_LLM_CONTEXT_URL=https://api.search.brave.com/res/v1/llm/context
# Max chars of Brave formatted text returned to the chat UI (GET /api/chat: brave_preview)
# BRAVE_UI_PREVIEW_CHARS=8000

# SSRF / crawl target safety
# By default, crawls are restricted to public http(s) hosts.
# Set this only when the app is protected and you intentionally crawl LAN/internal hosts.
ALLOW_PRIVATE_CRAWL_URLS=false
# Optional allowlist for internal crawl targets without allowing every private IP.
# Supports exact hostnames and wildcards like *.example.local
# CRAWL_ALLOWED_HOSTS=

# Extraction, chunking, and HTTP timeouts
CRAWL4AI_HTTP_TIMEOUT=60
SITEMAP_FETCH_TIMEOUT=30
CHUNK_MAX_TOKENS=900
CHUNK_OVERLAP_TOKENS=120

# Optional stale-site refresh scheduler
AUTO_REFRESH_ENABLED=false
AUTO_REFRESH_INTERVAL_HOURS=24
AUTO_REFRESH_STALE_AFTER_DAYS=30
AUTO_REFRESH_BATCH_LIMIT=3
# AUTO_REFRESH_MAX_URLS=50
AUTO_REFRESH_STARTUP_DELAY_SECONDS=30

# Crawl Configuration
# Set to 'url' for regular website or 'sitemap' for sitemap crawling, will crawl child pages from the sitemap
CRAWL_TYPE=url
# URL to crawl (can be a website URL or sitemap URL)
CRAWL_URL=https://example.com
# Maximum number of URLs to crawl from a sitemap (set to 0 for unlimited)
MAX_URLS=30
# Optional name for the site (if not provided, one will be generated)
CRAWL_SITE_NAME=
# Optional description for the site (if not provided, one will be generated)
CRAWL_SITE_DESCRIPTION=

# Chat Configuration
# Model to use for the chat interface (OpenAI id, e.g. gpt-4o, gpt-5.4-nano — note the dot in 5.4)
CHAT_MODEL=gpt-5.4-nano
# Max output tokens for assistant replies (main chat path; not prompt/context size). Default 1000.
# CHAT_MAX_COMPLETION_TOKENS=1000
# Greeting fast-path only (short “hi” replies). Default 150.
# CHAT_GREETING_MAX_COMPLETION_TOKENS=150
# gpt-5* / o-series use max_completion_tokens; set to 1 if your model still errors on max_tokens
# OPENAI_PREFER_MAX_COMPLETION_TOKENS=1
# Number of results to retrieve for each query (GET /api/search default is 10)
CHAT_RESULT_LIMIT=10
# Retrieval threshold (0-1). Same meaning as GET /api/search `threshold`; default 0.3.
# A chat --threshold CLI flag or webui query param overrides this per call.
CHAT_SIMILARITY_THRESHOLD=0.3
# Default session ID (if not provided, a new one will be generated) you can use aaaaaaaaaaaaa or a random string
CHAT_SESSION_ID=
# Default user ID (optional, name, user, i.e. larry)
CHAT_USER_ID=
# Default chat profile (default, pydantic, technical, concise, scifi, pirate, supabase_expert, medieval, etc.)
CHAT_PROFILE=default
# Directory containing profile YAML files
CHAT_PROFILES_DIR=profiles
# Verbose mode (true, false) - enable to see more during chat
CHAT_VERBOSE=false

# New Search plan (paid) Api key
BRAVE_API_KEY=""

