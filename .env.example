# Crawl4AI Configuration
#Locally ran in docker or external service - easily setup with docker compose - see crawl4ai github https://github.com/unclecode/crawl4ai
# Base URL: CRAWL4AI_URL or CRAWL4AI_BASE_URL (either name is accepted)
# CRAWL4AI_URL=https://your-crawl4ai-host
# Local Docker Use
# CRAWL4AI_BASE_URL=http://crawl4ai:11235 
CRAWL4AI_BASE_URL=your_crawl4ai_base_url

# API key is sent as header x-api-key: <value> (not Authorization: Bearer). CRAWL4AI_API_KEY or CRAWL4AI_API_TOKEN.
CRAWL4AI_API_KEY=your_crawl4ai_api_key
# CRAWL4AI_API_TOKEN=

# Traefik / Coolify Basic auth on the public URL (optional): Authorization: Basic user:pass
# CRAWL4AI_USER=
# CRAWL4AI_PASSWORD=
# (alias) CRAWL4AI_PASS=
# Optional override if your proxy expects a different header name for the Crawl4AI key
# CRAWL4AI_API_KEY_HEADER=x-api-key

# Supabase Configuration
# Option 1: Use a PostgreSQL connection string for Supabase connection pooler  this is free tier with ipv4 access
# SUPABASE_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-us-east-2.pooler.supabase.com:5432/postgres

# Option 2: Use a single URL (can be with or without protocol) supabase github https://github.com/supabase/supabase , example http://192.168.1.20:54322
SUPABASE_URL=your_supabase_host:port

# Option 3: Or use individual components
# SUPABASE_HOST=your_supabase_host
# SUPABASE_PORT=your_supabase_port

# Database credentials 
SUPABASE_DB=postgres
# For remote Supabase with connection pooler, you can also specify a different database user
# DB_USER=postgres.[YOUR-PROJECT-REF]
SUPABASE_KEY=postgres
SUPABASE_PASSWORD=postgres

# OpenAI Configuration
OPENAI_API_KEY=sk-proj-
# Model to use for embeddings
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Model to use for title and summary generation and chat analysis
OPENAI_CONTENT_MODEL=gpt-4o-mini

# API Hardening
# Optional comma-separated keys. If set, every /api request must send x-api-key or Authorization: Bearer.
# SCC_API_KEYS=
# Frontend value when SCC_API_KEYS is enabled:
# VITE_API_KEY=
# Comma-separated browser origins for CORS. Leave blank for local permissive mode.
# API_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# SSRF / crawl target safety
# By default, crawls are restricted to public http(s) hosts.
# Set this only when the app is protected and you intentionally crawl LAN/internal hosts.
ALLOW_PRIVATE_CRAWL_URLS=false
# Optional allowlist for internal crawl targets without allowing every private IP.
# Supports exact hostnames and wildcards like *.example.local
# CRAWL_ALLOWED_HOSTS=

# Extraction, chunking, and HTTP timeouts
CRAWL4AI_HTTP_TIMEOUT=60
SITEMAP_FETCH_TIMEOUT=30
CHUNK_MAX_TOKENS=900
CHUNK_OVERLAP_TOKENS=120

# Optional stale-site refresh scheduler
AUTO_REFRESH_ENABLED=false
AUTO_REFRESH_INTERVAL_HOURS=24
AUTO_REFRESH_STALE_AFTER_DAYS=30
AUTO_REFRESH_BATCH_LIMIT=3
# AUTO_REFRESH_MAX_URLS=50
AUTO_REFRESH_STARTUP_DELAY_SECONDS=30

# Crawl Configuration
# Set to 'url' for regular website or 'sitemap' for sitemap crawling, will crawl child pages from the sitemap
CRAWL_TYPE=url
# URL to crawl (can be a website URL or sitemap URL)
CRAWL_URL=https://example.com
# Maximum number of URLs to crawl from a sitemap (set to 0 for unlimited)
MAX_URLS=30
# Optional name for the site (if not provided, one will be generated)
CRAWL_SITE_NAME=
# Optional description for the site (if not provided, one will be generated)
CRAWL_SITE_DESCRIPTION=

# Chat Configuration
# Model to use for the chat interface (OpenAI id, e.g. gpt-4o, gpt-5.4-nano — note the dot in 5.4)
CHAT_MODEL=gpt-5.4-nano
# gpt-5* / o-series use max_completion_tokens; set to 1 if your model still errors on max_tokens
# OPENAI_PREFER_MAX_COMPLETION_TOKENS=1
# Number of results to retrieve for each query
CHAT_RESULT_LIMIT=5
# Similarity threshold for vector search (0-1)
CHAT_SIMILARITY_THRESHOLD=0.4
# Default session ID (if not provided, a new one will be generated) you can use aaaaaaaaaaaaa or a random string
CHAT_SESSION_ID=
# Default user ID (optional, name, user, i.e. larry)
CHAT_USER_ID=
# Default chat profile (default, pydantic, technical, concise, scifi, pirate, supabase_expert, medieval, etc.)
CHAT_PROFILE=default
# Directory containing profile YAML files
CHAT_PROFILES_DIR=profiles
# Verbose mode (true, false) - enable to see more during chat
CHAT_VERBOSE=false

